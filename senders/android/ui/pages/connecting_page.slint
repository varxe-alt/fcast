// connecting_page.slint — "Connecting" in-progress screen.
// Shown when AppState == Connecting.
// Extracted verbatim from main.slint.

import { VerticalBox } from "std-widgets.slint";
import { Bridge } from "../bridge.slint";
import { Theme } from "../theme.slint";
import { LoadingView, DestructiveButton } from "../components/buttons.slint";

export component ConnectingView inherits Rectangle {
    VerticalBox {
        LoadingView {
            label: "Connecting";
        }

        DestructiveButton {
            label: "Cancel";
            clicked => { Bridge.stop-casting(); }
        }
    }
}
