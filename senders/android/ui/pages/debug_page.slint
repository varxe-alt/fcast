// debug_page.slint — Debug / migration-test panel.
// Extracted from the inline `if Bridge.show-debug: VerticalBox { ... }` block
// that previously lived inside ConnectView in main.slint.
//
// Used as: `if Bridge.show-debug: DebugPage { }` inside connect_page.slint.
//
// The component inherits VerticalBox so that it participates correctly in the
// outer VerticalBox layout of ConnectView (same behaviour as the original
// inline VerticalBox).  `root` always refers to the DebugPage element itself,
// so `root.width` is used where the original code used `parent.width`.
//
// Slint docs ref (components / inherits):
//   draft/slint/docs/astro/src/content/docs/guide/language/coding/file.mdx

import { VerticalBox, ScrollView } from "std-widgets.slint";
import { Bridge, Panel } from "../bridge.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton, TextButton } from "../components/buttons.slint";

component DebugPageInner inherits VerticalBox {
    alignment: start;
    Text {
        horizontal-alignment: center;
        font-size: Theme.font-size-label;
        text: "Migrated server tests";
    }

    PrimaryButton {
        label: "Start Migrated Server";
        clicked => { Bridge.invoke-action("migrated-server"); }
    }

    TextButton {
        label: "Test Legacy GetInfo";
        clicked => { Bridge.invoke-action("test-getinfo"); }
    }

    TextButton {
        label: "Test Legacy Crossfade";
        clicked => { Bridge.invoke-action("test-crossfade"); }
    }

    TextButton {
        label: "Test Graph Smoke";
        clicked => { Bridge.invoke-action("test-smoke"); }
    }

    // Scrollable test-status log.
    // viewport-width uses root.width (the DebugPage/VerticalBox root element)
    // which is equivalent to the original `parent.width` that referred to the
    // outer VerticalBox in ConnectView.
    if Bridge.test-status != "": ScrollView {
        // Intrinsic test-log height; not tokenized (Phase 2-H).
        height: 100px;
        viewport-width: root.width;
        viewport-height: status-text.preferred-height;

        status-text := Text {
            width: parent.visible-width;
            wrap: word-wrap;
            text: Bridge.test-status;
        }
    }
}

export component FullDebugPage inherits Rectangle {
    width: 100%;
    height: 100%;
    background: Theme.surface-primary;

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: Theme.surface-card;
            HorizontalLayout {
                padding: Theme.padding-screen;
                Text {
                    text: "Debug panel";
                    color: Theme.text-primary;
                    font-size: Theme.font-size-heading;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                TextButton {
                    label: "Done";
                    clicked => { Bridge.active-panel = Panel.none; }
                }
            }
        }

        // ── Body ──────────────────────────────────────────────────────────
        VerticalLayout {
            padding: Theme.padding-screen;
            DebugPageInner {}
        }
    }
}

export component DebugPage inherits DebugPageInner {}
